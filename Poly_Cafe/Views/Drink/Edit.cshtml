@model Poly_Cafe.DTO.DrinkDTO
@{
    ViewData["Title"] = "Cập nhật đồ uống";
    Layout = "_Layout";
}

<style>
    /* Giao diện Card bo góc */
    .form-container {
        max-width: 800px;
        margin: 0 auto;
        padding-top: 20px;
    }

    .form-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        padding: 40px;
        position: relative;
    }

    .form-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 1px solid #f1f1f1;
    }

        .form-header h4 {
            font-weight: 700;
            color: #2d3436;
            margin: 0;
        }

    .btn-close-custom {
        background: none;
        border: none;
        font-size: 1.5rem;
        color: #b2bec3;
        cursor: pointer;
        text-decoration: none !important;
    }

        .btn-close-custom:hover {
            color: #d63031;
        }

    .form-label {
        font-size: 0.85rem;
        font-weight: 500;
        color: #636e72;
        margin-bottom: 8px;
    }

    .custom-input {
        border: 1px solid #dfe6e9;
        border-radius: 8px;
        padding: 12px 15px;
        font-size: 0.95rem;
        box-shadow: none !important;
    }

        .custom-input:focus {
            border-color: #8d6e63;
            box-shadow: 0 0 0 0.2rem rgba(141, 110, 99, 0.25) !important;
        }

    /* Khung upload và xem trước ảnh */
    .upload-area {
        border: 2px dashed #dfe6e9;
        border-radius: 12px;
        padding: 15px;
        text-align: center;
        cursor: pointer;
        background-color: #fcfcfc;
        position: relative;
        min-height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        transition: 0.3s;
    }

        .upload-area:hover {
            border-color: #8d6e63;
            background-color: #f5f5f5;
        }

        .upload-area img {
            max-width: 100%;
            max-height: 180px;
            object-fit: contain;
            border-radius: 8px;
        }

    .upload-icon {
        font-size: 3rem;
        color: #b2bec3;
    }

    .btn-change-image {
        position: absolute;
        bottom: 10px;
        right: 10px;
        background-color: rgba(255,255,255,0.9);
        color: #4e342e;
        border: 1px solid #dfe6e9;
        padding: 5px 15px;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    /* Vùng nút bấm hành động */
    .action-buttons {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #f1f1f1;
    }

    .btn-cancel {
        background-color: #f1f2f6;
        color: #2d3436;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        transition: 0.2s;
        border: none;
    }

        .btn-cancel:hover {
            background-color: #dfe6e9;
            color: #2d3436;
        }

    .btn-save {
        background-color: #4e342e;
        color: #fff;
        border: none;
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-save:hover {
            background-color: #3e2723;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
</style>

<div class="content-wrapper">
    <div class="form-container">
        <div class="form-card">
            <div class="form-header">
                <h4>Chỉnh sửa đồ uống</h4>
                <a href="/Drink" class="btn-close-custom"><i class="fas fa-times"></i></a>
            </div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger border-0 shadow-sm mb-4" style="border-radius: 10px;">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
                </div>
            }

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label">Tên đồ uống</label>
                        <input asp-for="Name" class="form-control custom-input" placeholder="Nhập tên đồ uống..." required />
                    </div>
                    <div class="col-md-6 mb-4">
                        <label class="form-label">Danh mục</label>
                        <select asp-for="CategoryId" class="form-select custom-input">
                            @if (ViewBag.Categories != null)
                            {
                                foreach (var cat in (IEnumerable<dynamic>)ViewBag.Categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label">Giá bán (VNĐ)</label>
                        <input asp-for="Price" type="number" class="form-control custom-input" placeholder="0" required min="0" />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Mô tả chi tiết</label>
                    <textarea asp-for="Description" class="form-control custom-input" rows="3" placeholder="Nhập mô tả cho món đồ uống..."></textarea>
                </div>

                <div class="mb-4">
                    <label class="form-label">Hình ảnh sản phẩm</label>
                    <div class="upload-area" onclick="document.getElementById('fileInput').click()">
                        @{
                            // Ưu tiên hiển thị ảnh từ thuộc tính Image
                            string displayImg = Model.Image;
                        }

                        @if (!string.IsNullOrEmpty(displayImg))
                        {
                            <img src="@displayImg" id="imagePreview" />
                            <i class="fas fa-mug-hot upload-icon" style="display:none;"></i>
                        }
                        else
                        {
                            <img src="" id="imagePreview" style="display:none;" />
                            <i class="fas fa-mug-hot upload-icon"></i>
                        }

                        <div class="btn-change-image"><i class="fas fa-camera me-1"></i> Thay đổi</div>
                        <input type="file" id="fileInput" name="ImageFile" style="display: none;" accept="image/*" />
                    </div>
                    <small class="text-muted mt-2 d-block text-center italic">* Click vào khung để chọn ảnh mới</small>
                </div>

                <div class="action-buttons">
                    <a href="/Drink" class="btn-cancel text-center">Hủy bỏ</a>
                    <button type="submit" class="btn-save">
                        <i class="fas fa-save me-2"></i> Lưu cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Xử lý xem trước ảnh khi chọn file mới
        document.getElementById('fileInput').addEventListener('change', function(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const preview = document.getElementById('imagePreview');
                    const icon = document.querySelector('.upload-icon');

                    preview.src = e.target.result;
                    preview.style.display = 'block';
                    if(icon) icon.style.display = 'none';
                }
                reader.readAsDataURL(file);
            }
        });
    </script>
}