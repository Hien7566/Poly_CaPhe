@model Poly_Cafe.DTO.DrinkDTO
@{
    ViewData["Title"] = "Thêm mới đồ uống";
    Layout = "_Layout";
}

<style>
    /* Canh giữa form và tạo khung nền trắng (Card) */
    .form-container { max-width: 800px; margin: 0 auto; }
    .form-card { background: #fff; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); padding: 40px; position: relative; }

    /* Phần Header của Form */
    .form-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #f1f1f1; }
    .form-header h4 { font-weight: 700; color: #2d3436; margin: 0; }
    .btn-close-custom { background: none; border: none; font-size: 1.5rem; color: #b2bec3; cursor: pointer; text-decoration: none; transition: 0.3s; }
    .btn-close-custom:hover { color: #d63031; }

    /* Style cho các ô Input giống Figma */
    .form-label { font-size: 0.85rem; font-weight: 500; color: #636e72; margin-bottom: 8px; }
    .custom-input { border: 1px solid #dfe6e9; border-radius: 8px; padding: 12px 15px; font-size: 0.95rem; color: #2d3436; box-shadow: none; transition: 0.3s; }
    .custom-input:focus { border-color: #8d6e63; box-shadow: 0 0 0 0.2rem rgba(141, 110, 99, 0.15); }

    /* Khung Upload Ảnh Dashed (Có hỗ trợ Xem trước ảnh) */
    .upload-area { border: 2px dashed #dfe6e9; border-radius: 12px; padding: 20px; text-align: center; cursor: pointer; transition: 0.3s; background-color: #fcfcfc; position: relative; min-height: 180px; display: flex; flex-direction: column; align-items: center; justify-content: center; overflow: hidden; }
    .upload-area:hover { border-color: #8d6e63; background-color: #fdfaf5; }
    .upload-icon { font-size: 2.5rem; color: #b2bec3; margin-bottom: 15px; }
    .upload-text { font-size: 0.9rem; color: #636e72; margin: 0; }
    .upload-subtext { font-size: 0.75rem; color: #b2bec3; }
    
    /* Chỉnh kích thước ảnh xem trước */
    #imagePreview { max-width: 100%; max-height: 160px; object-fit: contain; border-radius: 8px; display: none; }
    .btn-change-image { position: absolute; bottom: 10px; right: 10px; background-color: rgba(255,255,255,0.9); color: #4e342e; border: 1px solid #dfe6e9; padding: 5px 12px; border-radius: 6px; font-size: 0.8rem; font-weight: 600; display: none; }

    /* Khu vực Nút bấm */
    .action-buttons { display: flex; justify-content: flex-end; gap: 15px; margin-top: 30px; padding-top: 20px; border-top: 1px solid #f1f1f1; }
    .btn-cancel { background-color: #f1f2f6; color: #2d3436; border: none; padding: 10px 25px; border-radius: 8px; font-weight: 600; transition: 0.3s; text-decoration: none; }
    .btn-cancel:hover { background-color: #dfe6e9; color: #2d3436; }
    .btn-save { background-color: #4e342e; color: #fff; border: none; padding: 10px 25px; border-radius: 8px; font-weight: 600; transition: 0.3s; }
    .btn-save:hover { background-color: #3e2723; color: #fff; }
</style>

<div class="content-wrapper">
    <div class="form-container">
        <div class="form-card">
            <div class="form-header">
                <h4>Thêm mới đồ uống</h4>
                <a href="/Drink" class="btn-close-custom"><i class="fas fa-times"></i></a>
            </div>

            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label">Tên đồ uống</label>
                        <input name="Name" class="form-control custom-input" placeholder="Nhập tên đồ uống..." required />
                    </div>
                    <div class="col-md-6 mb-4">
                        <label class="form-label">Danh mục</label>
                        <select name="CategoryId" class="form-select custom-input">
                            @if (ViewBag.Categories != null)
                            {
                                foreach (var cat in ViewBag.Categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label">Giá bán (VNĐ)</label>
                        <input name="Price" type="number" class="form-control custom-input" placeholder="0" required />
                    </div>
                    <div class="col-md-6 mb-4">
                        <label class="form-label">Số lượng tồn (Tùy chọn)</label>
                        <input name="Stock" type="number" class="form-control custom-input" placeholder="0" />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Mô tả chi tiết (Tùy chọn)</label>
                    <textarea name="Description" class="form-control custom-input" rows="4" placeholder="Nhập mô tả cho món đồ uống..."></textarea>
                </div>

                <div class="mb-4">
                    <label class="form-label">Hình ảnh sản phẩm</label>
                    <div class="upload-area" onclick="document.getElementById('fileInput').click()">
                        
                        <div id="uploadPlaceholder">
                            <i class="fas fa-file-upload upload-icon"></i>
                            <p class="upload-text">Nhấn để tải lên hoặc kéo thả ảnh vào đây</p>
                            <span class="upload-subtext">PNG, JPG (Tối đa 5MB)</span>
                        </div>

                        <img id="imagePreview" src="#" alt="Xem trước ảnh" />
                        <div class="btn-change-image" id="btnChangeImg"><i class="fas fa-camera me-1"></i> Đổi ảnh</div>

                        <input type="file" id="fileInput" name="ImageFile" style="display: none;" accept="image/png, image/jpeg" />
                    </div>
                </div>

                <div class="action-buttons">
                    <a href="/Drink" class="btn-cancel">Hủy bỏ</a>
                    <button type="submit" class="btn-save">Lưu lại</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // JS để hiển thị ảnh xem trước ngay khi vừa chọn file
        document.getElementById('fileInput').addEventListener('change', function(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    // Hiện ảnh xem trước
                    const preview = document.getElementById('imagePreview');
                    preview.src = e.target.result;
                    preview.style.display = 'block'; 
                    
                    // Hiện nút Đổi ảnh
                    document.getElementById('btnChangeImg').style.display = 'block';

                    // Ẩn các icon/text mặc định
                    document.getElementById('uploadPlaceholder').style.display = 'none';
                }
                reader.readAsDataURL(file);
            }
        });
    </script>
}