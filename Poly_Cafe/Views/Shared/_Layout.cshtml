<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Poly Coffee</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --sidebar-bg: #4e342e; /* Nâu đậm Poly Coffee */
            --hover-bg: #6d4c41; /* Nâu sáng khi di chuột */
            --active-bg: #8d6e63; /* Nâu highlight khi đang ở trang đó */
            --text-color: #efebe9;
        }

        body {
            margin: 0;
            display: flex;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #fdfaf5;
        }

        /* Sidebar chính */
        .sidebar {
            width: 280px;
            background-color: var(--sidebar-bg);
            height: 100vh;
            color: var(--text-color);
            position: fixed;
            display: flex;
            flex-direction: column;
            box-shadow: 4px 0 10px rgba(0,0,0,0.1);
        }

        /* Logo & Tên quán */
        .sidebar-brand {
            padding: 30px 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

            .sidebar-brand i {
                font-size: 35px;
                margin-bottom: 10px;
                display: block;
                color: #d7ccc8;
            }

            .sidebar-brand h2 {
                margin: 0;
                font-size: 20px;
                letter-spacing: 2px;
                text-transform: uppercase;
            }

        /* Danh sách Menu */
        .nav-menu {
            list-style: none;
            padding: 20px 0;
            margin: 0;
            flex-grow: 1;
            overflow-y: auto;
        }

        .nav-item {
            margin: 4px 15px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            padding: 12px 15px;
            color: var(--text-color);
            text-decoration: none;
            gap: 12px;
            border-radius: 10px;
            transition: 0.3s;
            font-size: 15px;
        }

            .nav-link:hover {
                background-color: var(--hover-bg);
            }

        /* Trạng thái trang hiện tại */
        .nav-item.active .nav-link {
            background-color: var(--active-bg);
            font-weight: bold;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        }

        /* Phần dưới cùng (Đăng xuất) */
        .sidebar-footer {
            padding: 20px;
            border-top: 1px solid rgba(255,255,255,0.1);
        }

        .logout-btn {
            color: #d7ccc8;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 15px;
            transition: 0.3s;
        }

            .logout-btn:hover {
                color: #fff;
                transform: translateX(5px);
            }

        /* Nội dung bên phải */
        .main-content {
            margin-left: 280px;
            width: calc(100% - 280px);
            padding: 30px;
            min-height: 100vh;
        }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-brand">
            <i class="fas fa-coffee"></i>
            <h2>POLY COFFEE</h2>
            <small style="opacity: 0.7;">Quản lý cửa hàng</small>
        </div>

        <ul class="nav-menu" id="mainMenu">
            <li class="nav-item">
                <a href="@Url.Action("Index", "Dashboard")" class="nav-link">
                    <i class="fas fa-chart-pie"></i> Bảng điều khiển
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Index", "Bill")" class="nav-link">
                    <i class="fas fa-cash-register"></i> Bán hàng
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Index", "Drink")" class="nav-link">
                    <i class="fas fa-mug-hot"></i> Thực đơn đồ uống
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Index", "User")" class="nav-link">
                    <i class="fas fa-users-cog"></i> Quản lý nhân viên
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Index", "Shift")" class="nav-link">
                    <i class="fas fa-user-clock"></i> Quản lý ca làm
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Index", "Ingredient")" class="nav-link">
                    <i class="fas fa-blender"></i> Kho nguyên liệu
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Index", "Recipe")" class="nav-link">
                    <i class="fas fa-book-open"></i> Công thức pha chế
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Index", "Setting")" class="nav-link">
                    <i class="fas fa-cog"></i> Cài đặt hệ thống
                </a>
            </li>
        </ul>

        <div class="sidebar-footer">
            <a href="@Url.Action("Logout", "Home")" class="logout-btn">
                <i class="fas fa-sign-out-alt"></i> Đăng xuất
            </a>
        </div>
    </aside>

    <main class="main-content">
        @RenderBody()
    </main>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const currentPath = window.location.pathname.toLowerCase();
            const menuItems = document.querySelectorAll('.nav-item');

            menuItems.forEach(item => {
                const link = item.querySelector('.nav-link').getAttribute('href').toLowerCase();
                // Kiểm tra nếu đường dẫn hiện tại khớp với link menu
                if (currentPath.includes(link) && link !== "/") {
                    item.classList.add('active');
                } else if (currentPath === "/" && link.includes("dashboard")) {
                    item.classList.add('active');
                }
            });
        });
    </script>

</body>
</html>