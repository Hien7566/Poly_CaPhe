@model Poly_Cafe.DTO.DashboardDTO
@{
    ViewData["Title"] = "Bảng điều khiển";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    .dashboard-container {
    padding: 20px;
    }

    .dashboard-header {
    margin-bottom: 30px;
    }

    .dashboard-header h1 {
    font-size: 26px;
    font-weight: 700;
    color: #4a342e;
    margin: 0;
    }

    .dashboard-header .date {
    color: #8d6e63;
    font-weight: 500;
    }

    /* STATS GRID */
    .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
    }

    /* BIẾN STAT CARD THÀNH NÚT BẤM */
    .stat-card-link {
    text-decoration: none !important;
    color: inherit;
    display: block;
    transition: 0.2s ease;
    }

    .stat-card {
    background: white;
    padding: 25px;
    border-radius: 22px;
    display: flex;
    align-items: center;
    gap: 20px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    border: 1px solid transparent;
    height: 100%;
    }

    /* Hiệu ứng khi di chuột và nhấn */
    .stat-card-link:hover .stat-card {
    transform: translateY(-5px);
    border-color: #d7ccc8;
    background-color: #fdfaf8;
    }

    .stat-card-link:active .stat-card {
    transform: scale(0.97);
    box-shadow: inset 0 2px 5px rgba(0,0,0,0.05);
    }

    .stat-icon {
    width: 55px;
    height: 55px;
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    }

    .bg-green {
    background: #e8f5e9;
    color: #2ecc71;
    }

    .bg-blue {
    background: #e3f2fd;
    color: #3498db;
    }

    .bg-red {
    background: #ffebee;
    color: #e74c3c;
    }

    .bg-brown {
    background: #efebe9;
    color: #8d6e63;
    }

    .stat-info h3 {
    font-size: 13px;
    color: #8d6e63;
    margin-bottom: 5px;
    font-weight: 600;
    text-transform: uppercase;
    }

    .stat-value {
    font-size: 18px;
    font-weight: 800;
    color: #4a342e;
    }

    /* CHART SECTION */
    .charts-row {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 20px;
    margin-bottom: 30px;
    }

    .chart-card {
    background: white;
    padding: 25px;
    border-radius: 24px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    }

    .full-width {
    grid-column: span 2;
    }

    .alert-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px;
    background: #fffcf8;
    border-radius: 15px;
    margin-bottom: 10px;
    }
</style>

<div class="dashboard-container">
    <div class="dashboard-header">
        <h1>Chào mừng trở lại!</h1>
        <p class="date">@Model.TodayDate</p>
    </div>

    <div class="stats-row">
        <a asp-controller="Report" asp-action="Index" class="stat-card-link">
            <div class="stat-card">
                <div class="stat-icon bg-green"><i class="fas fa-money-bill-wave"></i></div>
                <div class="stat-info">
                    <h3>Doanh thu hôm nay</h3>
                    <div class="stat-value">@Model.TotalSalesToday.ToString("N0") đ</div>
                </div>
            </div>
        </a>

        <a asp-controller="Bill" asp-action="Index" class="stat-card-link">
            <div class="stat-card">
                <div class="stat-icon bg-blue"><i class="fas fa-shopping-bag"></i></div>
                <div class="stat-info">
                    <h3>Tổng đơn hàng</h3>
                    <div class="stat-value">@Model.TotalOrders</div>
                </div>
            </div>
        </a>

        <a asp-controller="Ingredient" asp-action="Index" class="stat-card-link">
            <div class="stat-card">
                <div class="stat-icon bg-red"><i class="fas fa-box-open"></i></div>
                <div class="stat-info">
                    <h3>Kho nguyên liệu</h3>
                    <div class="stat-value">@Model.LowStockItems</div>
                </div>
            </div>
        </a>

        <a asp-controller="Shift" asp-action="Index" class="stat-card-link">
            <div class="stat-card">
                <div class="stat-icon bg-brown"><i class="fas fa-user-friends"></i></div>
                <div class="stat-info">
                    <h3>Nhân viên trực</h3>
                    <div class="stat-value">@Model.ActiveCashiers</div>
                </div>
            </div>
        </a>
    </div>

    <div class="charts-row">
        <div class="chart-card">
            <h3>Xu hướng doanh thu</h3>
            <canvas id="salesTrendChart" style="max-height: 300px;"></canvas>
        </div>
        <div class="chart-card">
            <h3>Chi phí</h3>
            <canvas id="expensesChart" style="max-height: 250px;"></canvas>
        </div>
        <div class="chart-card full-width">
            <h3>Top sản phẩm bán chạy</h3>
            <canvas id="topProductsChart" style="max-height: 300px;"></canvas>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
    // Line Chart
    new Chart(document.getElementById('salesTrendChart'), {
    type: 'line',
    data: {
    labels: ['Thứ 2', 'Thứ 3', 'Thứ 4', 'Thứ 5', 'Thứ 6', 'Thứ 7', 'CN'],
    datasets: [{
    label: 'Doanh thu (VNĐ)',
    data: [1500000, 2400000, 2100000, 2800000, 3200000, 3500000, 3100000],
    borderColor: '#4a342e',
    backgroundColor: 'rgba(74, 52, 46, 0.05)',
    fill: true, tension: 0.4
    }]
    }
    });

    // Doughnut Chart
    new Chart(document.getElementById('expensesChart'), {
    type: 'doughnut',
    data: {
    labels: ['Điện', 'Nguyên liệu', 'Lương', 'Khác'],
    datasets: [{
    data: [15, 30, 45, 10],
    backgroundColor: ['#8d6e63', '#a1887f', '#4a342e', '#d7ccc8']
    }]
    }
    });

    // Bar Chart
    new Chart(document.getElementById('topProductsChart'), {
    type: 'bar',
    data: {
    labels: ['Espresso', 'Bạc xỉu', 'Cappuccino', 'Cà phê muối', 'Bánh'],
    datasets: [{
    label: 'Số đơn',
    data: [450, 380, 320, 280, 210],
    backgroundColor: '#8d6e63'
    }]
    }
    });
    });
</script>