@model IEnumerable<Poly_Cafe.DTO.CustomerDTO>
@{
    ViewData["Title"] = "Quản lý khách hàng";
    Layout = "_Layout";

    // Thống kê khách hàng
    int totalCustomers = Model?.Count() ?? 0;
    int vvipCount = Model?.Count(c => c.Customer_Type == "VVIP" || c.Customer_Type == "VIP") ?? 0;
    int activeCount = Model?.Count(c => c.Active) ?? 0;
}

@functions {
    // Hàm cắt 2 chữ cái đầu làm Avatar
    public string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "KH";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        return (parts[0].Substring(0, 1) + parts[parts.Length - 1].Substring(0, 1)).ToUpper();
    }
}

<style>
    .content-wrapper { font-family: 'Segoe UI', sans-serif; background-color: #f5ece4; padding: 30px; border-radius: 10px; min-height: 100vh; }
    
    .page-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 25px; }
    .page-title { font-size: 1.4rem; font-weight: 700; color: #4a3b32; margin: 0 0 5px 0; }
    .page-subtitle { font-size: 0.9rem; color: #7a6f6f; margin: 0; }
    .btn-add { background-color: #4a3b32; color: #ffffff; border: none; padding: 10px 18px; border-radius: 8px; font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: 0.3s; }
    .btn-add:hover { background-color: #312620; color: #ffffff; }
    
    .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 20px; }
    .stat-card { background: #ffffff; padding: 20px 25px; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.02); display: flex; justify-content: space-between; align-items: flex-start; }
    .stat-text p { margin: 0; color: #7a6f6f; font-size: 0.9rem; margin-bottom: 15px; }
    .stat-text h3 { margin: 0; font-size: 1.4rem; color: #4a3b32; font-weight: 700; }
    .stat-icon { width: 35px; height: 35px; display: flex; justify-content: center; align-items: center; font-size: 1.2rem; border-radius: 8px; }
    
    .search-container { background: #ffffff; padding: 15px 20px; border-radius: 12px; margin-bottom: 25px; display: flex; align-items: center; gap: 15px; box-shadow: 0 2px 8px rgba(0,0,0,0.02); }
    .search-container i { color: #a09595; }
    .search-container input { border: none; width: 100%; outline: none; font-size: 0.95rem; color: #4a3b32; }
    
    .users-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(48%, 1fr)); gap: 20px; }
    .user-card { background: #ffffff; border-radius: 12px; padding: 25px; box-shadow: 0 2px 8px rgba(0,0,0,0.02); position: relative; }
    
    .uc-header { display: flex; gap: 15px; align-items: center; margin-bottom: 20px; }
    .uc-avatar { width: 45px; height: 45px; background: #4a3b32; color: #ffffff; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-weight: 700; font-size: 1.05rem; }
    .uc-name { margin: 0 0 3px 0; font-weight: 700; color: #4a3b32; font-size: 1.1rem; }
    .uc-email { margin: 0; color: #7a6f6f; font-size: 0.85rem; }
    
    .uc-actions { position: absolute; top: 25px; right: 25px; display: flex; gap: 15px; }
    .uc-actions a, .uc-actions button { color: #a09595; background: none; border: none; padding: 0; cursor: pointer; transition: 0.2s; font-size: 1.1rem; text-decoration: none;}
    .uc-actions a:hover { color: #4a3b32; }
    .uc-actions button:hover { color: #d63031; }
    
    .uc-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; font-size: 0.9rem; }
    .uc-label { color: #7a6f6f; }
    .uc-value { color: #4a3b32; font-weight: 500;}
    
    /* Huy hiệu Hạng thẻ */
    .badge-vvip { background: linear-gradient(45deg, #ffd700, #ff8c00); color: white; padding: 4px 15px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; box-shadow: 0 2px 5px rgba(255,140,0,0.3); }
    .badge-vip { background: #e1b12c; color: white; padding: 4px 15px; border-radius: 20px; font-size: 0.8rem; font-weight: 600;}
    .badge-thanthiet { background: #4cd137; color: white; padding: 4px 15px; border-radius: 20px; font-size: 0.8rem; font-weight: 600;}
    .badge-thuong { background: #f1f3f4; color: #5f6368; padding: 4px 15px; border-radius: 20px; font-size: 0.8rem; font-weight: 600;}
    
    .uc-divider { border: 0; height: 1px; background: #f0ebe4; margin: 15px 0; }
    .address-text { font-size: 0.85rem; color: #7a6f6f; display: flex; align-items: center; gap: 8px; }
</style>

<div class="content-wrapper">
    <div class="page-header">
        <div>
            <h1 class="page-title">Quản lý Khách hàng</h1>
            <p class="page-subtitle">Quản lý thông tin và hạng thẻ thành viên</p>
        </div>
        <a href="/Customer/Create" class="btn-add"><i class="fas fa-plus"></i> Thêm khách hàng</a>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-text">
                <p>Tổng khách hàng</p>
                <h3>@totalCustomers</h3>
            </div>
            <div class="stat-icon" style="color: #4a3b32; background: #f5ece4;"><i class="fas fa-users"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-text">
                <p>Đang có thẻ hoạt động</p>
                <h3>@activeCount</h3>
            </div>
            <div class="stat-icon" style="color: #2e7d32; background: #e8f5e9;"><i class="fas fa-id-card"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-text">
                <p>Khách VIP / VVIP</p>
                <h3>@vvipCount</h3>
            </div>
            <div class="stat-icon" style="color: #e65100; background: #fff3e0;"><i class="fas fa-crown"></i></div>
        </div>
    </div>

    <div class="search-container">
        <i class="fas fa-search"></i>
        <input type="text" id="searchInput" placeholder="Tìm kiếm theo tên, số điện thoại hoặc email...">
    </div>

    <div class="users-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="user-card">
                    <div class="uc-actions">
                        <a href="/Customer/Edit/@item.Id" title="Chỉnh sửa"><i class="far fa-edit"></i></a>
                        <form action="/Customer/Delete/@item.Id" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa khách hàng này?');">
                            <button type="submit" title="Xóa"><i class="far fa-trash-alt"></i></button>
                        </form>
                    </div>

                    <div class="uc-header">
                        <div class="uc-avatar">@GetInitials(item.Full_Name)</div>
                        <div>
                            <h4 class="uc-name">@item.Full_Name</h4>
                            <p class="uc-email"><i class="fas fa-phone-alt me-1"></i> @item.Phone</p>
                        </div>
                    </div>

                    <div class="uc-row">
                        <span class="uc-label">Hạng thành viên:</span>
                        <span>
                            @if (item.Customer_Type == "VVIP") { <span class="badge-vvip"><i class="fas fa-crown me-1"></i>VVIP</span> }
                            else if (item.Customer_Type == "VIP") { <span class="badge-vip">VIP</span> }
                            else if (item.Customer_Type == "Thân thiết") { <span class="badge-thanthiet">Thân thiết</span> }
                            else { <span class="badge-thuong">Thường</span> }
                        </span>
                    </div>

                    <div class="uc-row">
                        <span class="uc-label">Tổng chi tiêu:</span>
                        <span class="uc-value" style="color: #d63031; font-weight: 700;">@item.Total_Spent.ToString("N0") ₫</span>
                    </div>

                    <div class="uc-row">
                        <span class="uc-label">Giới tính:</span>
                        <span class="uc-value">@(string.IsNullOrEmpty(item.Gender) ? "---" : item.Gender)</span>
                    </div>

                    <hr class="uc-divider" />

                    <div class="address-text">
                        <i class="fas fa-map-marker-alt"></i> @(string.IsNullOrEmpty(item.Address) ? "Chưa cập nhật địa chỉ" : item.Address)
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('input', function () {
            var keyword = this.value.toLowerCase().trim();
            var cards = document.querySelectorAll('.user-card');
            cards.forEach(function (card) {
                var text = card.textContent.toLowerCase();
                card.style.display = text.includes(keyword) ? '' : 'none'; 
            });
        });
    </script>
}