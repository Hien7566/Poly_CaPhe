@{
    ViewData["Title"] = "Trang chủ";
}

<div class="text-center">
    <h1 class="display-4">Chào mừng đến với Poly Cafe</h1>
    <p>Hệ thống quản lý quán cafe</p>
</div>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Danh mục</h5>
                <p class="card-text">@ViewBag.Categories?.Count danh mục</p>
                <a asp-controller="Category" asp-action="Index" class="btn btn-primary">Quản lý</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Đồ uống</h5>
                <p class="card-text">@ViewBag.Drinks?.Count món</p>
                <a asp-controller="Drink" asp-action="Index" class="btn btn-primary">Quản lý</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Nhân viên</h5>
                <p class="card-text">Quản lý nhân viên</p>
                <a asp-controller="User" asp-action="Index" class="btn btn-primary">Quản lý</a>
            </div>
        </div>
    </div>
</div>